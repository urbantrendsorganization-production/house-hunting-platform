# Keja production env (Phase 7). Copy to ops/compose/.env and fill with REAL
# secrets on the Hetzner box. NEVER commit the filled-in file. Placeholders only.

# Django
DJANGO_SECRET_KEY=generate-a-50-char-random-string
# Includes `api` — the website (web container) fetches the API server-side over
# the internal network as http://api:8000, so that Host must be allowed too.
ALLOWED_HOSTS=api.keja.urbantrends.dev,keja.urbantrends.dev,api
CSRF_TRUSTED_ORIGINS=https://api.keja.urbantrends.dev,https://keja.urbantrends.dev
# Browser origins allowed to call the API cross-origin (the website).
CORS_ALLOWED_ORIGINS=https://keja.urbantrends.dev

# Published API image (GHCR). Pin to a sha for reproducible deploys.
API_IMAGE=ghcr.io/urbantrendsorganization-production/house-hunting-platform/api:latest

# Postgres / PostGIS
POSTGRES_PASSWORD=a-strong-db-password

# Object storage — self-hosted MinIO (see the minio service in the compose).
# MinIO root creds; the API uses the SAME values as its AWS access key/secret.
MINIO_ROOT_USER=keja-minio
MINIO_ROOT_PASSWORD=a-strong-minio-password
# Public S3 endpoint (host Caddy -> minio). Presigned URLs are built from this,
# so it MUST be the public https host the phone/browser can reach.
AWS_S3_ENDPOINT_URL=https://s3.keja.urbantrends.dev
AWS_ACCESS_KEY_ID=keja-minio                 # = MINIO_ROOT_USER
AWS_SECRET_ACCESS_KEY=a-strong-minio-password  # = MINIO_ROOT_PASSWORD
AWS_STORAGE_BUCKET_NAME=keja-media

# Domains — used for ALLOWED_HOSTS/CSRF above and the NEXT_PUBLIC_* below.
# TLS is terminated by the shared HOST reverse proxy, not this stack.
API_DOMAIN=api.keja.urbantrends.dev
WEB_DOMAIN=keja.urbantrends.dev

# Loopback host ports the host reverse proxy points at (127.0.0.1 only).
# Must not clash with other stacks on the box (3000 3001 5000 8000 8001 8083 8086).
API_HOST_PORT=8087
WEB_HOST_PORT=3002

# Website (Next.js). NEXT_PUBLIC_* are baked into the client bundle at BUILD
# time — changing any of them requires a rebuild (`up -d --build web`), not just
# a restart. Sensible defaults derive from API_DOMAIN/WEB_DOMAIN if left unset.
NEXT_PUBLIC_API_BASE=https://api.keja.urbantrends.dev/api/v1
NEXT_PUBLIC_SITE_URL=https://keja.urbantrends.dev
# KE-restricted Google Maps JS key. Blank => /map degrades to a list.
NEXT_PUBLIC_GOOGLE_MAPS_KEY=
# App distribution links for the /download page (blank => "coming soon").
NEXT_PUBLIC_PLAY_STORE_URL=
NEXT_PUBLIC_CONSUMER_APK_URL=
NEXT_PUBLIC_AGENT_APK_URL=
# Server-side (SSR) fetch base — read at runtime. Use the PUBLIC https host, not
# http://api:8000: SECURE_SSL_REDIRECT 301-redirects internal plain-http calls.
API_BASE=https://api.keja.urbantrends.dev/api/v1

# Error monitoring (Sentry or self-hosted GlitchTip). Leave blank to disable.
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# Backups
BACKUP_DIR=/srv/keja/backups
BACKUP_RETENTION_DAYS=14
