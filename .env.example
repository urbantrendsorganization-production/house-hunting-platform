# Copy to .env for local overrides. NEVER commit real secrets.
# Placeholder values only — the compose file already wires sane local defaults.

DEBUG=true
DJANGO_SECRET_KEY=change-me-in-real-environments
ALLOWED_HOSTS=*

# Postgres / PostGIS
DATABASE_URL=postgis://keja:keja@db:5432/keja

# Redis (cache + celery broker)
REDIS_URL=redis://redis:6379/0

# S3-compatible object storage (minio locally)
AWS_S3_ENDPOINT_URL=http://minio:9000
AWS_ACCESS_KEY_ID=minio
AWS_SECRET_ACCESS_KEY=minio12345
AWS_STORAGE_BUCKET_NAME=keja-media
AWS_S3_REGION_NAME=us-east-1

# Freshness rules
VACANCY_DEMOTE_DAYS=14
VACANCY_HIDE_DAYS=30

# --- Monitoring (Phase 7) ---
# Requests slower than this (ms) are logged to the keja.slow logger. 0 disables.
SLOW_REQUEST_MS=500
LOG_LEVEL=INFO
# Set WARNING->DEBUG to log every SQL statement while profiling.
DB_LOG_LEVEL=WARNING
# Error monitoring (Sentry or self-hosted GlitchTip). Blank = disabled (no-op).
SENTRY_DSN=
SENTRY_ENVIRONMENT=local

# --- Production only (see ops/env/prod.env.example) ---
# When DEBUG=false these harden cookies/HSTS/SSL-redirect. Behind Caddy, keep
# SECURE_SSL_REDIRECT=true. CSRF_TRUSTED_ORIGINS is needed for the admin.
# SECURE_SSL_REDIRECT=true
# CSRF_TRUSTED_ORIGINS=https://api.keja.example,https://keja.example

# --- Google Maps keys ---
# Do NOT put real keys here (this file is committed). Each key lives with the
# surface that uses it, in a git-ignored location:
#   * Web Maps (Maps JS)     -> ops/compose/.env  NEXT_PUBLIC_GOOGLE_MAPS_KEY (server)
#   * Android Maps (SDK)     -> consumer_app/android/local.properties  MAPS_API_KEY
#   * Places (autocomplete)  -> consumer_app/dart_defines.json  PLACES_API_KEY
