# Copy to .env for local overrides. NEVER commit real secrets.
# Placeholder values only — the compose file already wires sane local defaults.

DEBUG=true
DJANGO_SECRET_KEY=change-me-in-real-environments
ALLOWED_HOSTS=*

# Postgres / PostGIS
DATABASE_URL=postgis://keja:keja@db:5432/keja

# Redis (cache + celery broker)
REDIS_URL=redis://redis:6379/0

# S3-compatible object storage (minio locally)
AWS_S3_ENDPOINT_URL=http://minio:9000
AWS_ACCESS_KEY_ID=minio
AWS_SECRET_ACCESS_KEY=minio12345
AWS_STORAGE_BUCKET_NAME=keja-media
AWS_S3_REGION_NAME=us-east-1

# Freshness rules
VACANCY_DEMOTE_DAYS=14
VACANCY_HIDE_DAYS=30
