# Copy to android/key.properties on the RELEASE build machine and fill with real
# values. This file (key.properties) and the keystore are git-ignored — NEVER
# commit them. Losing the keystore means you can never update the app again, so
# back it up somewhere safe (password manager / secrets vault).
#
# Create the keystore once (use a SEPARATE keystore/alias from the consumer app):
#   keytool -genkey -v -keystore ~/keja-agent-upload.jks -keyalg RSA \
#           -keysize 2048 -validity 10000 -alias keja-agent
#
storePassword=CHANGE_ME
keyPassword=CHANGE_ME
keyAlias=keja-agent
# Absolute path to the .jks, or relative to android/app/ :
storeFile=/absolute/path/to/keja-agent-upload.jks
