# Django API base. Server components fetch via API_BASE; the browser uses
# NEXT_PUBLIC_API_BASE (must be reachable from the user's device).
API_BASE=http://localhost:8000/api/v1
NEXT_PUBLIC_API_BASE=http://localhost:8000/api/v1

# Public site URL (robots/sitemap canonical).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Maps JS API key (KE-restricted). Without it, /map degrades to a list.
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# App distribution links for /download (blank => "coming soon" state shown).
# Consumer app goes to Google Play; the agent app is a direct APK download
# (internal, device-bound field tool — not a Play Store listing).
NEXT_PUBLIC_PLAY_STORE_URL=
NEXT_PUBLIC_CONSUMER_APK_URL=
NEXT_PUBLIC_AGENT_APK_URL=
